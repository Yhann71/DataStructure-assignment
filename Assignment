// ─────────────────────────────────────────────
//  MERGE SORT — by Total Monthly Emission
// ─────────────────────────────────────────────
void merge(Resident arr[], int left, int mid, int right) {
    int n1 = mid - left + 1;
    int n2 = right - mid;

    Resident* L = new Resident[n1];
    Resident* R = new Resident[n2];

    for (int i = 0; i < n1; i++) L[i] = arr[left + i];
    for (int j = 0; j < n2; j++) R[j] = arr[mid + 1 + j];

    int i = 0, j = 0, k = left;
    while (i < n1 && j < n2) {
        if (L[i].totalMonthlyEmission <= R[j].totalMonthlyEmission)
            arr[k++] = L[i++];
        else
            arr[k++] = R[j++];
    }
    while (i < n1) arr[k++] = L[i++];
    while (j < n2) arr[k++] = R[j++];

    delete[] L;
    delete[] R;
}

void mergeSort(Resident arr[], int left, int right) {
    if (left >= right) return;
    int mid = left + (right - left) / 2;
    mergeSort(arr, left, mid);
    mergeSort(arr, mid + 1, right);
    merge(arr, left, mid, right);
}

// ─────────────────────────────────────────────
//  MERGE SORT — by Age
// ─────────────────────────────────────────────
void mergeAge(Resident arr[], int left, int mid, int right) {
    int n1 = mid - left + 1;
    int n2 = right - mid;
    Resident* L = new Resident[n1];
    Resident* R = new Resident[n2];
    for (int i = 0; i < n1; i++) L[i] = arr[left + i];
    for (int j = 0; j < n2; j++) R[j] = arr[mid + 1 + j];
    int i = 0, j = 0, k = left;
    while (i < n1 && j < n2) {
        if (L[i].age <= R[j].age) arr[k++] = L[i++];
        else                       arr[k++] = R[j++];
    }
    while (i < n1) arr[k++] = L[i++];
    while (j < n2) arr[k++] = R[j++];
    delete[] L;
    delete[] R;
}

void mergeSortByAge(Resident arr[], int left, int right) {
    if (left >= right) return;
    int mid = left + (right - left) / 2;
    mergeSortByAge(arr, left, mid);
    mergeSortByAge(arr, mid + 1, right);
    mergeAge(arr, left, mid, right);
}

// ─────────────────────────────────────────────
//  MERGE SORT — by Daily Distance
// ─────────────────────────────────────────────
void mergeDist(Resident arr[], int left, int mid, int right) {
    int n1 = mid - left + 1;
    int n2 = right - mid;
    Resident* L = new Resident[n1];
    Resident* R = new Resident[n2];
    for (int i = 0; i < n1; i++) L[i] = arr[left + i];
    for (int j = 0; j < n2; j++) R[j] = arr[mid + 1 + j];
    int i = 0, j = 0, k = left;
    while (i < n1 && j < n2) {
        if (L[i].dailyDistance <= R[j].dailyDistance) arr[k++] = L[i++];
        else                                           arr[k++] = R[j++];
    }
    while (i < n1) arr[k++] = L[i++];
    while (j < n2) arr[k++] = R[j++];
    delete[] L;
    delete[] R;
}

void mergeSortByDistance(Resident arr[], int left, int right) {
    if (left >= right) return;
    int mid = left + (right - left) / 2;
    mergeSortByDistance(arr, left, mid);
    mergeSortByDistance(arr, mid + 1, right);
    mergeDist(arr, left, mid, right);
}

// ─────────────────────────────────────────────
//  LINEAR SEARCH — by Resident ID
// ─────────────────────────────────────────────
int linearSearchByID(Resident arr[], int size, const string& id) {
    for (int i = 0; i < size; i++) {
        if (arr[i].residentID == id)
            return i;
    }
    return -1;
}

// ─────────────────────────────────────────────
//  LINEAR SEARCH — by Age Group
// ─────────────────────────────────────────────
int linearSearchByAgeGroup(Resident arr[], int size, const string& ageGroup,
                            Resident results[], int& count) {
    count = 0;
    for (int i = 0; i < size; i++) {
        if (arr[i].ageGroup == ageGroup) {
            results[count++] = arr[i];
        }
    }
    return count;
}

// ─────────────────────────────────────────────
//  LINEAR SEARCH — by Transport Mode
// ─────────────────────────────────────────────
int linearSearchByTransport(Resident arr[], int size, const string& mode,
                             Resident results[], int& count) {
    count = 0;
    for (int i = 0; i < size; i++) {
        if (arr[i].modeOfTransport == mode) {
            results[count++] = arr[i];
        }
    }
    return count;
}

// ─────────────────────────────────────────────
//  LINEAR SEARCH — by Distance Threshold (> X km)
// ─────────────────────────────────────────────
int linearSearchByDistance(Resident arr[], int size, double threshold,
                            Resident results[], int& count) {
    count = 0;
    for (int i = 0; i < size; i++) {
        if (arr[i].dailyDistance > threshold) {
            results[count++] = arr[i];
        }
    }
    return count;
}

// ─────────────────────────────────────────────
//  CARBON EMISSION ANALYSIS — per Age Group
// ─────────────────────────────────────────────
void carbonEmissionAnalysis(Resident arr[], int size) {
    // Age groups
    const int NUM_GROUPS = 5;
    string groups[NUM_GROUPS] = {
        "6-17: Children & Teenagers",
        "18-25: University Students / Young Adults",
        "26-45: Working Adults (Early Career)",
        "46-60: Working Adults (Late Career)",
        "61-100: Senior Citizens / Retirees"
    };

    // Transport modes
    const int NUM_MODES = 7;
    string modes[NUM_MODES] = {"Car","Bus","Bicycle","Walking","School Bus","Carpool","Other"};

    cout << "\n";
    printDivider(75);
    cout << "  CARBON EMISSION ANALYSIS BY AGE GROUP\n";
    printDivider(75);

    for (int g = 0; g < NUM_GROUPS; g++) {
        double groupTotal = 0;
        int    groupCount = 0;

        // Count per mode
        int    modeCounts[NUM_MODES]    = {};
        double modeEmissions[NUM_MODES] = {};

        for (int i = 0; i < size; i++) {
            if (arr[i].ageGroup == groups[g]) {
                groupTotal += arr[i].totalMonthlyEmission;
                groupCount++;
                for (int m = 0; m < NUM_MODES; m++) {
                    if (arr[i].modeOfTransport == modes[m]) {
                        modeCounts[m]++;
                        modeEmissions[m] += arr[i].totalMonthlyEmission;
                        break;
                    }
                }
            }
        }
        if (groupCount == 0) continue;

        cout << "\nAge Group: " << groups[g] << "\n";
        printDivider(65);
        cout << left
             << setw(16) << "Mode of Transport"
             << setw(8)  << "Count"
             << setw(24) << "Total Emission (kg CO2)"
             << setw(22) << "Average per Resident"
             << "\n";
        printDivider(65);

        for (int m = 0; m < NUM_MODES; m++) {
            if (modeCounts[m] == 0) continue;
            double avg = modeEmissions[m] / modeCounts[m];
            cout << left
                 << setw(16) << modes[m]
                 << setw(8)  << modeCounts[m]
                 << setw(24) << fixed << setprecision(2) << modeEmissions[m]
                 << setw(22) << fixed << setprecision(2) << avg
                 << "\n";
        }
        printDivider(65);
        cout << "Total Emission for Age Group: "
             << fixed << setprecision(2) << groupTotal << " kg CO2"
             << "  |  Residents: " << groupCount
             << "  |  Avg: " << fixed << setprecision(2) << groupTotal / groupCount
             << " kg CO2\n";
    }
}

// ─────────────────────────────────────────────
//  CARBON EMISSION ANALYSIS — per City
// ─────────────────────────────────────────────
void emissionByCity(Resident arr[], int size) {
    string cities[3]    = {"City A", "City B", "City C"};
    double totals[3]    = {};
    int    counts[3]    = {};

    for (int i = 0; i < size; i++) {
        for (int c = 0; c < 3; c++) {
            if (arr[i].city == cities[c]) {
                totals[c] += arr[i].totalMonthlyEmission;
                counts[c]++;
            }
        }
    }

    cout << "\n";
    printDivider(60);
    cout << "  TOTAL CARBON EMISSION COMPARISON BY CITY\n";
    printDivider(60);
    cout << left
         << setw(12) << "City"
         << setw(12) << "Residents"
         << setw(22) << "Total Emission(kg CO2)"
         << setw(20) << "Avg per Resident"
         << "\n";
    printDivider(60);
    for (int c = 0; c < 3; c++) {
        double avg = (counts[c] > 0) ? totals[c] / counts[c] : 0;
        cout << left
             << setw(12) << cities[c]
             << setw(12) << counts[c]
             << setw(22) << fixed << setprecision(2) << totals[c]
             << setw(20) << fixed << setprecision(2) << avg
             << "\n";
    }
    printDivider(60);
}

