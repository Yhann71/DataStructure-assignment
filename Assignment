            t2 = high_resolution_clock::now();
            printTime("Search by Distance (>15 km):", duration_cast<microseconds>(t2 - t1).count());

            cout << "\n  [MEMORY USAGE ESTIMATE]\n";
            cout << "  Size of one Resident struct: ~" << sizeof(Resident) << " bytes\n";
            cout << "  Total for " << totalSize << " records  : ~"
                 << (sizeof(Resident) * totalSize) / 1024.0 << " KB\n";

            cout << "\n  [ARRAY ADVANTAGES]\n";
            cout << "  + O(1) random access by index\n";
            cout << "  + Cache-friendly (contiguous memory)\n";
            cout << "  + Simple to implement and debug\n";
            cout << "\n  [ARRAY DISADVANTAGES]\n";
            cout << "  - Fixed size (MAX_SIZE must be declared upfront)\n";
            cout << "  - Insertion/deletion shifts elements: O(n)\n";
            printDivider(60);
        }

        else if (choice != 0) {
            cout << "  Invalid choice. Try again.\n";
        }

    } while (choice != 0);

    cout << "\n  Goodbye!\n\n";
    return 0;
}
